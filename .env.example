# ──────────────────────────────────────────────────────────────────
# VigIA v2.0 · Configuración de proveedores IA
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir .env a un repositorio de código.
# ──────────────────────────────────────────────────────────────────

# Proveedor activo: "claude" | "azure" | "ollama"
AI_PROVIDER=claude

# ── Claude (Anthropic) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_CLAVE

# ── Azure OpenAI ───────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://mi-empresa.openai.azure.com/
AZURE_OPENAI_API_KEY=REEMPLAZAR_CON_TU_CLAVE_AZURE
AZURE_OPENAI_DEPLOYMENT=gpt-4o-coto
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Ollama (Local / Self-hosted) ────────────────────────────────────
# URL del servidor Ollama (ej: http://localhost:11434)
OLLAMA_URL=http://localhost:11434
# Modelo disponible en Ollama (ej: mistral, llama2, neural-chat, etc)
OLLAMA_MODEL=mistral
